# Copy to .deploy.env and fill in your hosting details.
# Never commit .deploy.env.

# ─── SSH (recommended) ───
# cPanel → SSH Access, or ask your host for SSH login details.
SSH_HOST=amyash.co.uk
SSH_USER=your-cpanel-username
SSH_PORT=22
# Full path to web root (cPanel is usually /home/USERNAME/public_html)
SSH_REMOTE_DIR=/home/your-cpanel-username/public_html
# Optional: path to private key if not using default (~/.ssh/id_ed25519)
# SSH_KEY=~/.ssh/id_ed25519
# Set true to remove server files not in dist/ (use with care)
SSH_DELETE=false

# ─── FTP (alternative) ───
FTP_HOST=ftp.amyash.co.uk
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_REMOTE_DIR=/public_html
FTP_SECURE=true
